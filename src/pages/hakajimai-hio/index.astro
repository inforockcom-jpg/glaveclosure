---
import Layout from '../../layouts/Layout.astro';

const siteUrl = 'https://graveclosure.xyz';
const pagePath = '/hakajimai-hio/';
const pageUrl = new URL(pagePath, siteUrl).toString();

const pageTitle = '墓じまいの費用相場と安く抑えるコツ | 追加料金なしのコミコミ安心プラン | ここから';
const pageDescription = '墓じまいの費用でお悩みなら。不透明な総額費用のクリア化、他社比較、安く抑える3つのコツを解説。追加料金なしのコミコミ安心パック（180,000円〜）をご案内。';

const contactTel = '070-8428-0866';
const contactLineUrl = 'https://lin.ee/QzDuTbn';
const heroImageUrl = '/assets/hakajimai_hio_fv.png';
const supportImageUrl = 'https://graveclosure.xyz/assets/japanese_temoto_kuyo.png';

// FAQPage schema JSON-LD for AIO optimization
const jsonLdData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      logo: `${siteUrl}/assets/favicon.png`,
      telephone: contactTel
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      inLanguage: 'ja-JP'
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDescription,
      inLanguage: 'ja-JP',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: [{ '@id': `${pageUrl}#service` }, { '@id': `${pageUrl}#faq` }],
      breadcrumb: { '@id': `${pageUrl}#breadcrumb` }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: '墓じまいの費用相場と安く抑えるコツ', item: pageUrl }
      ]
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: '墓じまいには総額でどのくらいの費用がかかりますか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text: '墓じまいの総額費用は一般的に30万円〜150万円が相場です。主な内訳は、①お墓の解体撤去工事費用（1平方メートルあたり約10万〜15万円）、②お寺への離檀料や閉眼供養のお布施（約3万〜20万円）、③次の移行先での永代供養や納骨等の供養先費用（数万〜数十万円）の3大費用です。「ここから」では、追加料金なしのコミコミ安心プランを180,000円からご案内しており、不透明な費用をクリアにしています。'
          }
        },
        {
          '@type': 'Question',
          name: '墓じまいの費用を安く抑えるコツはありますか？',
          acceptedAnswer: {
            '@type': 'Answer',
            text: '墓じまい費用を安く抑えるコツは主に3つあります。1つ目は「複数社からの相見積もり」で解体撤去費用の適正価格を確認すること。2つ目は「自治体の墓じまい補助金や支援制度の活用」で、数万〜数十万円の支給を受けられる場合があります。3つ目は「手元供養や散骨など柔軟な移行先を選択する」ことで、高額な永代供養墓や新たな納骨堂の購入費用を大幅に削減できます。'
          }
        }
      ]
    }
  ]
};

const jsonLd = JSON.stringify(jsonLdData);
---

<Layout title={pageTitle} description={pageDescription} canonicalPath={pagePath} jsonLd={jsonLd}>
  <a href="#main-content" class="skip-link">本文へスキップ</a>
  <main id="main-content">
    <article aria-labelledby="hero-title">
      <!-- FV (First View) -->
      <header class="fv" style={`background-image: url('${heroImageUrl}'); background-size: cover; background-position: center; color: white; padding: 100px 20px; text-align: center; position: relative;`}>
        <div class="fv-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.45);"></div>
        <div class="container" style="position: relative; z-index: 1;">
          <div class="hero-status" aria-label="受付情報">
            <span class="hero-status-badge">追加料金なし</span>
            <span class="hero-status-badge" style="background: rgba(201,131,43,0.95);">見積もり完全無料</span>
            <span class="hero-status-badge">24時間全国受付中</span>
          </div>
          
          <div class="fv-brand">ここから</div>
          <h1 id="hero-title" class="fv-title" style="font-size: 3.2rem; font-weight: 900; line-height: 1.35; margin-bottom: 20px; text-shadow: 0 3px 15px rgba(0,0,0,0.6);">
            不透明な墓じまい費用をクリアに。<br />追加料金なしのコミコミ安心プラン
          </h1>
          <p class="fv-subtitle" style="font-size: 1.5rem; font-weight: 700; color: #cfe9dd; margin-bottom: 30px; text-shadow: 0 2px 8px rgba(0,0,0,0.5);">
            【総額180,000円〜】解体から行政サポートまで全て含んだ明朗会計
          </p>

          <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 24px;">
            <a href="#cta" class="btn btn-primary btn-shine" style="font-size: 1.25rem; padding: 18px 40px; box-shadow: 0 6px 20px rgba(201, 131, 43, 0.45);">無料で費用を見積もる</a>
          </div>
        </div>
      </header>

      <!-- Sticky CTA for Mobile -->
      <aside class="sticky-cta" aria-label="お問い合わせ導線">
        <a href={contactLineUrl} class="btn btn-line btn-shine" target="_blank" rel="noopener noreferrer">
          <span>24時間相談OK</span>
          <strong>LINE相談</strong>
        </a>
        <a href={`tel:${contactTel}`} class="btn btn-tel btn-shine">
          <span>通話料・見積無料</span>
          <strong>電話相談</strong>
        </a>
      </aside>

      <!-- FV直下: 墓地面積ごとの相場表（縦並びでスマホ対応） -->
      <section class="section" id="area-pricing" style="background-color: #ffffff; padding: 60px 0;" aria-labelledby="area-pricing-heading">
        <div class="container">
          <header class="text-center" style="max-width: 800px; margin: 0 auto 40px;">
            <span style="color: var(--color-trust-blue); font-weight: 700; font-size: 1.1rem; letter-spacing: 0.1em; text-transform: uppercase; display: block; margin-bottom: 10px;">CLEAR PRICE</span>
            <h2 id="area-pricing-heading" style="font-size: 2.2rem; font-weight: 800; color: var(--text-main);">墓地面積ごとの費用相場と「ここから」の料金プラン</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 15px; line-height: 1.6;">
              お墓の広さに応じた一般的な解体撤去費用相場と、当社のコミコミ安心パック料金の比較です。スマホでも見やすいよう縦並びで表示しています。
            </p>
          </header>

          <div class="pricing-card-list">
            <!-- 1平米未満 -->
            <article class="pricing-card-item" style="border-left: 6px solid var(--color-trust-blue);">
              <div class="pricing-card-left">
                <div class="pricing-card-area">極小区画 (〜1㎡)</div>
                <div class="pricing-card-size">マンション墓地や小さな個人墓地に多い広さです。</div>
              </div>
              <div class="pricing-card-right">
                <div class="pricing-card-price-box market">
                  <div class="price-label">一般的な解体費用相場</div>
                  <div class="price-value">約10万〜15万円</div>
                </div>
                <div class="pricing-card-price-box kokokara">
                  <div class="price-label">ここからのコミコミ安心プラン</div>
                  <div class="price-value highlight">100,000円<span style="font-size: 1rem; font-weight: 700;">〜</span></div>
                </div>
              </div>
            </article>

            <!-- 2平米未満 -->
            <article class="pricing-card-item" style="border-left: 6px solid var(--color-trust-blue);">
              <div class="pricing-card-left">
                <div class="pricing-card-area">小規模区画 (〜2㎡)</div>
                <div class="pricing-card-size">一般的な公営霊園や民営霊園に多い標準的なサイズです。</div>
              </div>
              <div class="pricing-card-right">
                <div class="pricing-card-price-box market">
                  <div class="price-label">一般的な解体費用相場</div>
                  <div class="price-value">約20万〜30万円</div>
                </div>
                <div class="pricing-card-price-box kokokara">
                  <div class="price-label">ここからのコミコミ安心プラン</div>
                  <div class="price-value highlight">180,000円<span style="font-size: 1rem; font-weight: 700;">〜</span></div>
                </div>
              </div>
            </article>

            <!-- 3平米未満 -->
            <article class="pricing-card-item" style="border-left: 6px solid var(--color-trust-blue);">
              <div class="pricing-card-left">
                <div class="pricing-card-area">中規模区画 (〜3㎡)</div>
                <div class="pricing-card-size">地方の墓地や、少しゆとりのあるお墓に多い広さです。</div>
              </div>
              <div class="pricing-card-right">
                <div class="pricing-card-price-box market">
                  <div class="price-label">一般的な解体費用相場</div>
                  <div class="price-value">約30万〜45万円</div>
                </div>
                <div class="pricing-card-price-box kokokara">
                  <div class="price-label">ここからのコミコミ安心プラン</div>
                  <div class="price-value highlight">270,000円<span style="font-size: 1rem; font-weight: 700;">〜</span></div>
                </div>
              </div>
            </article>

            <!-- 4平米未満 -->
            <article class="pricing-card-item" style="border-left: 6px solid var(--color-trust-blue);">
              <div class="pricing-card-left">
                <div class="pricing-card-area">大規模区画 (〜4㎡)</div>
                <div class="pricing-card-size">代々受け継がれてきた広い区画や外柵がしっかりしたお墓です。</div>
              </div>
              <div class="pricing-card-right">
                <div class="pricing-card-price-box market">
                  <div class="price-label">一般的な解体費用相場</div>
                  <div class="price-value">約40万〜60万円</div>
                </div>
                <div class="pricing-card-price-box kokokara">
                  <div class="price-label">ここからのコミコミ安心プラン</div>
                  <div class="price-value highlight">360,000円<span style="font-size: 1rem; font-weight: 700;">〜</span></div>
                </div>
              </div>
            </article>
          </div>
          <p style="max-width: 860px; margin: 24px auto 0; font-size: 1rem; color: var(--text-muted); line-height: 1.5; text-align: center;">
            ※上記料金には、お墓の解体撤去工事、更地化、行政手続きサポート、産業廃棄物処理費用がすべて含まれています。<br />
            ※傾斜地、重機が入らない狭小地など、現地状況により別途見積もりが必要となる場合がございますが、事前に必ず総額をお出しします。
          </p>
        </div>
      </section>

      <!-- お悩みセクション（Empathy） -->
      <section class="section empathy" id="concerns" aria-labelledby="concerns-heading">
        <div class="container">
          <h2 id="concerns-heading" class="text-center" style="font-size: 2.1rem; font-weight: 800; margin-bottom: 15px;">墓じまいの費用で、こんなお悩みはありませんか？</h2>
          <p class="text-center" style="color: var(--text-muted); margin-bottom: 45px; font-size: 1.15rem;">お墓の整理は多くの方にとって一生に一度。費用が不透明なことで不安を感じるのは当然です。</p>
          <div class="grid-3">
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 15px; color: var(--text-main);">他社の見積もりが高すぎて妥当かわからない</h3>
              <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                石材店によって見積もり額に数十万円以上の差があることも珍しくありません。「この金額が適正なのかどうか」判断がつかず、困惑してしまう方が非常に多いです。
              </p>
            </div>
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 15px; color: var(--text-main);">離檀料や閉眼供養のお布施など寺院費用が不安</h3>
              <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                これまでお世話になったお寺へ渡す「離檀料」や「閉眼法要のお布施」について、相場が明文化されておらず、いくら包めば失礼がないか不安を抱かれる方が多くいます。
              </p>
            </div>
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.35rem; font-weight: 700; margin-bottom: 15px; color: var(--text-main);">工事の後から追加料金を請求されないか不安</h3>
              <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                「事前の見積もりは安かったのに、解体後に『地中の障害物の処理費用』や『重機使用料』を別途請求された」といった、石材店との金銭トラブルを懸念されるご相談が増えています。
              </p>
            </div>
          </div>
          <div class="card" style="max-width: 900px; margin: 40px auto 0; background: #fffdf9; border: 1px solid rgba(201, 131, 43, 0.25); text-align: center; padding: 24px;">
            <p style="font-size: 1.2rem; font-weight: 700; color: var(--text-main); line-height: 1.6;">
              「ここから」は、不透明になりがちな墓じまいの総額費用を契約前にすべてクリア化。<br />
              追加料金一切なしのコミコミ安心パックで、お客様のご不安を完全に解消します。
            </p>
          </div>
        </div>
      </section>

      <!-- メインコンテンツ1：総額費用のクリア化（3大内訳の解説） -->
      <section class="section" id="cost-breakdown" style="background-color: #ffffff;" aria-labelledby="cost-breakdown-heading">
        <div class="container">
          <header class="text-center" style="max-width: 800px; margin: 0 auto 50px;">
            <span style="color: var(--color-trust-blue); font-weight: 700; font-size: 1.1rem; letter-spacing: 0.1em; display: block; margin-bottom: 10px;">BREAKDOWN</span>
            <h2 id="cost-breakdown-heading" style="font-size: 2.2rem; font-weight: 800;">墓じまいにかかる「総額費用」の3大内訳</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 15px; line-height: 1.6;">
              墓じまい費用の総額が不透明に感じられるのは、性質の異なる複数の出費が重なるためです。お墓の整理に必要な費用は、大きく分けて以下の3つに分類されます。
            </p>
          </header>

          <div style="max-width: 960px; margin: 0 auto; display: grid; gap: 40px;">
            <!-- 内訳1 -->
            <div class="card" style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px; align-items: center; padding: 35px;">
              <div style="text-align: center; background: #eef4fb; padding: 30px; border-radius: 12px;">
                <span style="font-size: 0.9rem; font-weight: 700; color: var(--color-trust-blue); display: block; margin-bottom: 8px;">内訳 その①</span>
                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin-bottom: 10px;">お墓の解体撤去費用</h3>
                <div style="font-size: 2rem; font-weight: 900; color: var(--color-trust-blue);">10万〜60<span style="font-size: 1.1rem;">万円</span></div>
                <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-top: 6px;">(※お墓の面積による)</span>
              </div>
              <div>
                <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-main); margin-bottom: 12px; border-left: 4px solid var(--color-trust-blue); padding-left: 10px;">墓石の撤去と区画の更地化にかかる実費</h4>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 12px;">
                  墓石の解体・運搬・処分、基礎コンクリートの掘り起こし、真砂土を入れて平らにする更地化工事、と産業廃棄物としての墓石の処理費用が含まれます。
                </p>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                  <strong>【費用変動の要因】</strong> 墓地の立地が斜面にある場合や、通路が極端に狭くクレーン車や重機が入らない手作業工事となる場合は、人工（人件費）が増えるため相場が高くなります。
                </p>
              </div>
            </div>

            <!-- 内訳2 -->
            <div class="card" style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px; align-items: center; padding: 35px;">
              <div style="text-align: center; background: #fdf5ec; padding: 30px; border-radius: 12px;">
                <span style="font-size: 0.9rem; font-weight: 700; color: var(--color-accent-gold); display: block; margin-bottom: 8px;">内訳 その②</span>
                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin-bottom: 10px;">お寺への離檀料・お布施</h3>
                <div style="font-size: 2rem; font-weight: 900; color: var(--color-accent-gold);">3万〜20<span style="font-size: 1.1rem;">万円</span></div>
                <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-top: 6px;">(※一般的な感謝の目安)</span>
              </div>
              <div>
                <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-main); margin-bottom: 12px; border-left: 4px solid var(--color-accent-gold); padding-left: 10px;">寺院への感謝を示すお気持ちと儀式の費用</h4>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 12px;">
                  これまでご先祖をお守りいただいたお寺の檀家を離れる際にお渡しする「離檀料」や、お墓から魂を抜く「閉眼供養（魂抜き）」の法要に対するお布施です。
                </p>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                  <strong>【費用変動 of 要因】</strong> 離檀料は本来お寺への「感謝の布施」であり、法律上の支払義務はありませんが、トラブル防止のために一般的な法要のお布施1〜3回分（3万〜10万円程度）を包むのが主流です。
                </p>
              </div>
            </div>

            <!-- 内訳3 -->
            <div class="card" style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px; align-items: center; padding: 35px;">
              <div style="text-align: center; background: #f4fbf7; padding: 30px; border-radius: 12px;">
                <span style="font-size: 0.9rem; font-weight: 700; color: var(--color-affirm-green); display: block; margin-bottom: 8px;">内訳 その③</span>
                <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text-main); margin-bottom: 10px;">次の供養先の移行費用</h3>
                <div style="font-size: 2rem; font-weight: 900; color: var(--color-affirm-green);">5万〜100<span style="font-size: 1.1rem;">万円</span></div>
                <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-top: 6px;">(※選択する供養法による)</span>
              </div>
              <div>
                <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-main); margin-bottom: 12px; border-left: 4px solid var(--color-affirm-green); padding-left: 10px;">取り出したご遺骨を新たに供養する費用</h4>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 12px;">
                  お墓から取り出したご遺骨は放置できず、別の場所へ納骨する必要があります。合祀される永代供養墓、個別の納骨堂、樹木葬、あるいは自宅で綺麗に保管する手元供養、海洋散骨などが挙げられます。
                </p>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                  <strong>【費用変動の要因】</strong> 新たに高額な個別の納骨堂（50万〜150万円）を契約すると総額費用が跳ね上がりますが、共同墓への永代供養（5万〜10万円）や手元供養（5万円〜）にすることで費用を大幅に削減できます。
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- メインコンテンツ2：他社との費用比較テーブル -->
      <section class="section" id="comparison" style="background-color: #f7fafc;" aria-labelledby="comparison-heading">
