---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="ブログ | ここから" description="墓じまい案内専門「ここから」のブログです。">
	<main class="container section">
		<h1 class="text-center" style="margin-bottom: 2rem; font-size: 2.5rem; color: #2C3E50;">ブログ</h1>
		
		<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 2rem;">
			{posts.map((post) => (
				<article style="background: #fff; padding: 1.5rem; border-radius: 12px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
					<a href={`/blog/${post.slug}/`} style="text-decoration: none; color: inherit;">
						{post.data.heroImage && (
							<img src={post.data.heroImage} alt="" style="width: 100%; border-radius: 8px; margin-bottom: 1rem;" />
						)}
						<h2 style="font-size: 1.5rem; margin-bottom: 0.5rem; color: #2f8f6b;">{post.data.title}</h2>
						<p style="color: #666; font-size: 0.9rem; margin-bottom: 1rem;">
							<time datetime={post.data.pubDate.toISOString()}>
								{post.data.pubDate.toLocaleDateString('ja-JP', {
									year: 'numeric',
									month: 'long',
									day: 'numeric',
								})}
							</time>
						</p>
						<p style="color: #444;">{post.data.description}</p>
					</a>
				</article>
			))}
		</div>
	</main>
</Layout>
