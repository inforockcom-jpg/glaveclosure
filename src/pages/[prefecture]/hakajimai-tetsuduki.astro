---
import Layout from '../../layouts/Layout.astro';
import { prefectures, type Prefecture } from '../../data/prefectures';

export async function getStaticPaths() {
  return prefectures.map((prefecture) => ({
    params: { prefecture: prefecture.slug },
    props: { prefecture }
  }));
}

const { prefecture } = Astro.props as { prefecture: Prefecture };

const siteUrl = 'https://graveclosure.xyz';
const pagePath = `/${prefecture.slug}/hakajimai-tetsuduki/`;
const pageUrl = new URL(pagePath, siteUrl).toString();

const pageTitle = `${prefecture.name}での墓じまいの手続き・流れを完全解説 | 行政手続き・お寺調整の丸投げプラン | ここから`;
const pageDescription = `${prefecture.name}での墓じまいの面倒な行政手続き（改葬許可申請など）や寺院との調整でお悩みの方へ。遠方対応可能、現地訪問不要で手続きを丸投げできる安心プランをご案内。${prefecture.primaryCity}など${prefecture.name}全域に対応。`;

const contactTel = '070-8428-0866';
const contactLineUrl = 'https://lin.ee/QzDuTbn';
const heroImageUrl = '/assets/hakajimai_tetsuduki_fv.png';
const supportImageUrl = '/assets/japanese_temoto_kuyo.png';

// Category-based copy variations for AIO performance
const categoryCopy = {
  snow: {
    feature: `${prefecture.name}の積雪・気候条件を熟知した専門スタッフが、冬場でも行政手続きの先行申請やお寺様との交渉調整を円滑に進め、春先の雪解けと同時に速やかに解体更地化工事を開始できる安心スケジュールをご提案します。`,
    empathy: `特に冬場は現地お墓までの道路状況が非常に厳しく、高齢のご親族だけでは役所窓口やお墓の確認に行くことすら命がけとなります。`,
  },
  metro: {
    feature: `${prefecture.name}の主要都市（${prefecture.primaryCity}など）のスピード役所手続きや、お住まいが都市部（東京都内・大阪市内・名古屋市内など）で仕事が忙しく平日に全く動けない方向けに、完全代理（委任状のみの郵送取り交わし）での書類代理取得を徹底して行います。`,
    empathy: `平日は役所の窓口が開いている時間に電話すら一本かけるのが難しく、手続きの最初の一歩で心が折れてしまう方が非常に多いのが現状です。`,
  },
  standard: {
    feature: `${prefecture.name}地域のお寺・霊園それぞれの慣習に配慮し、檀家をやめる「離檀手続き」で揉めないためのご家族・ご親族への事前説明アドバイスや、役所への改葬申請書の書き方を丁寧に完全サポートします。`,
    empathy: `親族間で「本当に墓じまいしてよいのか」という話し合いや、お寺にどうやって切り出せばいいかという精神的な負担で悩まれるケースが非常に多いです。`,
  }
};

const curCategory = categoryCopy[prefecture.category];

// FAQPage schema @graph JSON-LD for AIO optimization with regional references
const jsonLdData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      logo: `${siteUrl}/assets/favicon.png`,
      telephone: contactTel
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      inLanguage: 'ja-JP'
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDescription,
      inLanguage: 'ja-JP',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: [
        { '@id': `${pageUrl}#service` },
        { '@id': `${pageUrl}#localbusiness` }
      ],
      breadcrumb: { '@id': `${pageUrl}#breadcrumb` }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: `${prefecture.name}の墓じまい案内`, item: `${siteUrl}/${prefecture.slug}/` },
        { '@type': 'ListItem', position: 3, name: `${prefecture.name}の墓じまい手続きと行政の流れ`, item: pageUrl }
      ]
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: '墓じまい行政手続き代行・更地化工事監理',
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: {
        '@type': 'AdministrativeArea',
        name: prefecture.name
      },
      description: `${prefecture.name}での改葬許可申請代行、お墓解体工事の行政報告手続き、寺院への閉眼法要段取り代行、必要書類の職権取得（行政書士連携）を含む完全丸投げサービス。`
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${pageUrl}#localbusiness`,
      name: `墓じまい・手元供養案内専門 ここから ${prefecture.name}エリア手続き相談所`,
      telephone: contactTel,
      address: {
        '@type': 'PostalAddress',
        addressRegion: prefecture.name,
        addressLocality: prefecture.primaryCity,
        addressCountry: 'JP'
      },
      areaServed: [
        { '@type': 'AdministrativeArea', name: prefecture.name },
        { '@type': 'AdministrativeArea', name: prefecture.primaryCity }
      ],
      sameAs: [
        'https://www.mhlw.go.jp/stf/seisakunitsuite/bunya/kenkou_iryou/kenkou/seikatsu-eisei/seikatsu-eisei04/index.html',
        'https://ja.wikipedia.org/wiki/%E6%94%B9%E8%91%AC'
      ]
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: `${prefecture.name}内でお墓の手続き（改葬）はどのように進めればよいですか？`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `${prefecture.name}でのお墓の手続きは「改葬許可申請」が必須となります。現在の墓地がある市区町村（${prefecture.primaryCity}など）の役所から改葬許可申請書を入手し、現在のお墓の管理者（お寺や霊園）から「埋蔵証明書」、新しい供養先から「受入証明書」を取得した上で役所に提出し、「改葬許可証」を交付してもらいます。「ここから」では、これら一連の行政手続きや書類取得の郵送・代理サポートをワンストップで承っております。`
          }
        },
        {
          '@type': 'Question',
          name: `現在遠方に住んでいますが、${prefecture.name}にある実家のお墓の手続きや解体を完全非対面で進めることは可能ですか？`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `はい、完全に非対面かつ一度も${prefecture.name}の現地を訪れることなく墓じまいを完了することが可能です。行政手続き（改葬許可申請等の代理取得）は郵送書面による代理申請や行政書士との連携で行い、解体工事についても現地調査・工事開始前・更地化完了の写真をデジタルデータ（LINE等）でご報告するため、交通費や時間をかけることなくスマートに完了します。`
          }
        }
      ]
    }
  ]
};

const jsonLd = JSON.stringify(jsonLdData);
---

<Layout title={pageTitle} description={pageDescription} canonicalPath={pagePath} jsonLd={jsonLd}>
  <a href="#main-content" class="skip-link">本文へスキップ</a>
  <main id="main-content">
    <article aria-labelledby="hero-title">
      
      <!-- FV (First View) -->
      <header class="fv" style={`background-image: url('${heroImageUrl}'); background-size: cover; background-position: center; color: white; padding: 120px 20px; text-align: center; position: relative; min-height: 90vh; display: flex; align-items: center; justify-content: center;`}>
        <div class="fv-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(17, 28, 41, 0.88) 0%, rgba(34, 50, 71, 0.65) 100%);"></div>
        <div class="container" style="position: relative; z-index: 1; max-width: 850px;">
          <div class="hero-status" aria-label="受付情報">
            <span class="hero-status-badge">${prefecture.name}対応</span>
            <span class="hero-status-badge" style="background: var(--color-trust-blue);">完全非対面・現地訪問不要</span>
            <span class="hero-status-badge" style="background: var(--color-affirm-green);">24時間相談受付中</span>
          </div>
          
          <div style="background: rgba(255,255,255,0.96); color: var(--text-main); padding: 20px 26px; border-radius: 14px; font-weight: 700; font-size: 1.15rem; max-width: 780px; margin: 0 auto 28px auto; border-left: 6px solid var(--color-affirm-green); text-align: left; box-shadow: 0 10px 25px rgba(0,0,0,0.18); line-height: 1.7;">
            <p style="margin: 0; font-size: 1.05rem; color: var(--text-muted); font-weight: 500; margin-bottom: 4px;">面倒な行政手続き・お寺との調整にお悩みの方へ</p>
            役所への改葬許可申請、お寺への離檀交渉・お布施調整から、墓石の更地解体まで。すべてプロに任せて安心の「手続き代行安心プラン」をご案内。
          </div>
          
          <div class="fv-brand" style="margin-bottom: 10px;">ここから</div>
          <h1 id="hero-title" class="fv-title" style="font-size: 3.2rem; line-height: 1.35; margin-bottom: 24px; font-weight: 900; text-shadow: 0 3px 15px rgba(0,0,0,0.4);">
            面倒な${prefecture.name}での墓じまい手続きを<br />
            すべてプロに丸投げ。<br />
            現地訪問不要の「安心代行」
          </h1>
          <p class="fv-subtitle" style="font-size: 1.45rem; line-height: 1.6; max-width: 720px; margin: 0 auto 36px auto; font-weight: 500; color: rgba(255,255,255,0.95);">
            「お墓が${prefecture.name}にあるが遠方で戻れない」「仕事で役所に行けない」という方も、完全非対面で書類取得からお寺の調整、更地返還まで完結します。
          </p>
          
          <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px;">
            <span class="hero-status-badge" style="background: var(--color-accent-gold); padding: 8px 18px;">相談・現地見積もり完全無料</span>
            <span class="hero-status-badge" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); padding: 8px 18px;">遠方・オンライン対応</span>
          </div>
        </div>
      </header>

      <!-- Sticky CTA for Mobile -->
      <aside class="sticky-cta" aria-label="お問い合わせ導線">
        <a href={contactLineUrl} class="btn btn-line btn-shine" target="_blank" rel="noopener noreferrer">
          <span>24時間相談OK</span>
          <strong>LINE相談</strong>
        </a>
        <a href={`tel:${contactTel}`} class="btn btn-tel btn-shine">
          <span>通話料・見積無料</span>
          <strong>電話相談</strong>
        </a>
      </aside>

      <!-- 面倒な手続き解説セクション -->
      <section class="section" id="pain-points" style="background: #ffffff; padding: 80px 0;" aria-labelledby="pain-heading">
        <div class="container">
          <header class="text-center" style="max-width: 800px; margin: 0 auto 50px;">
            <span style="color: var(--color-alert-red); font-weight: 700; font-size: 1.1rem; letter-spacing: 1px; display: block; margin-bottom: 10px;">PROBLEMS</span>
            <h2 id="pain-heading" style="font-size: 2.2rem; font-weight: 800; color: var(--text-main);">墓じまいに必要な「複雑すぎる手続き」に疲れていませんか？</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 15px; line-height: 1.6;">
              墓じまいは、単にお墓を壊す「土木工事」だけではありません。法律（墓地、埋葬等に関する法律）に基づき、複雑な行政手続きと宗教的な調整を正確に進める必要があります。
            </p>
          </header>

          <div class="grid-3" style="margin-bottom: 40px;">
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; color: var(--text-main);">① 平日に何度も役所に行かなければならない</h3>
              <p style="font-size: 1.02rem; line-height: 1.7; color: var(--text-muted);">
                改葬許可申請書の入手、現在の墓地がある${prefecture.name}内の役所（${prefecture.primaryCity}など）への提出、必要書類（埋蔵証明・受入証明など）の収集など、すべて役所の開いている「平日の日中」に動かなければなりません。
              </p>
            </div>
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; color: var(--text-main);">② お寺様への切り出し・調整に大きな心理的負担</h3>
              <p style="font-size: 1.02rem; line-height: 1.7; color: var(--text-muted);">
                檀家を離れる「離檀」交渉は、最もトラブルになりやすい場面です。「なんてお伝えすれば失礼がないか」「高額な離檀料を請求されるのでは」と、胃が痛む思いで悩んでいる方が大勢いらっしゃいます。
              </p>
            </div>
            <div class="card" style="border-top: 4px solid var(--color-alert-red);">
              <h3 style="font-size: 1.3rem; font-weight: 700; margin-bottom: 12px; color: var(--text-main);">③ 遠方のお墓まで、現地確認・立ち会いのための往復</h3>
              <p style="font-size: 1.02rem; line-height: 1.7; color: var(--text-muted);">
                お墓がある場所（例：${prefecture.localCaseCity}）が現在住んでいる場所から離れている場合、石材店に見積もりを依頼するための現地確認や、閉眼供養（法要）、工事の立ち会いなどで、交通費だけで何万円も失い、時間と体力を浪費してしまいます。
              </p>
            </div>
          </div>

          <div class="card" style="max-width: 900px; margin: 0 auto; background: #fffdf9; border: 1px solid rgba(47, 143, 107, 0.2); padding: 25px; text-align: center;">
            <p style="font-size: 1.15rem; font-weight: 700; color: var(--text-main); line-height: 1.6; margin: 0;">
              ご安心ください。${curCategory.feature}<br />
              お客様は、委任状等の簡単な郵送書類にご署名・ご捺印いただくだけ。あとはすべての進捗をLINE等でゆったり待つだけです。
            </p>
          </div>
        </div>
      </section>

      <!-- フロー（タイムライン）詳細解説セクション -->
      <section class="section" id="timeline" style="background-color: #f7fafc; padding: 80px 0;" aria-labelledby="timeline-heading">
        <div class="container">
          <header class="text-center" style="max-width: 800px; margin: 0 auto 40px;">
            <span style="color: var(--color-trust-blue); font-weight: 700; font-size: 1.1rem; letter-spacing: 1px; display: block; margin-bottom: 10px;">FLOW TIMELINE</span>
            <h2 id="timeline-heading" style="font-size: 2.2rem; font-weight: 800; color: var(--text-main);">墓じまいの具体的な7ステップと「丸投げ代行」範囲</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 15px; line-height: 1.6;">
              ご相談からご遺骨の新たな場所へのご納骨（改葬完了）までの具体的な流れです。水色の枠内（行政手続き・実質調整作業）は、「ここから」がすべて責任を持って代行・サポートします。
            </p>
          </header>

          <div class="timeline-container">
            <div class="timeline-item">
              <div class="timeline-badge">1</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 1</span>
                  お問い合わせ＆無料ヒアリング
                </h3>
                <p class="timeline-text">
                  現在のお墓の場所（例：${prefecture.name}〇〇市、〇〇霊園など）やお分かりになる限りの状況、改葬後のご遺骨の新たな供養先のご希望（手元供養や永代供養墓など）を公式LINEやお電話でご相談ください。専任の担当アドバイザーが丁寧に状況をお聞きします。
                </p>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-badge">2</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 2</span>
                  【代行】現地調査・石材店相見積もり＆新供養先の決定
                </h3>
                <p class="timeline-text">
                  提携する優良石材店が現地を直接確認し、お墓の寸法・構造や、重機の搬入条件などを正確に調査。その情報に基づいて「追加料金一切なし」の総額コミコミお見積もりを作成・ご提示します。同時に、墓じまい後にご遺骨を収める新しい場所（手元供養セットや提携永代供養先）を予算に合わせて選びます。
                </p>
                <div class="timeline-detail-box">
                  <strong>ここからの代行範囲：</strong>遠方で立ち会えないお客様に代わり、提携石材店の手配および現場調査日程の調整、立ち会い検証をすべて代行します。調査時の現場写真もお送りします。
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-badge">3</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 3</span>
                  【代行】改葬許可申請書などの必要書類の取得
                </h3>
                <p class="timeline-text">
                  墓じまい（改葬）を法的に行うために、現在お墓がある${prefecture.name}内の役所から「改葬許可申請書」を取り寄せ、さらに現在のお墓の管理者から「埋蔵（収蔵）証明書」を取得します。
                </p>
                <div class="timeline-detail-box">
                  <strong>ここからの代行範囲：</strong>役所からの申請書取り寄せ手続きを完全代行。提携法律家（行政書士）が代理となって、お墓に埋葬されている方全員分の証明書や申請書の必要事項記入サポート、書類の整理を行います。
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-badge">4</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 4</span>
                  【代行】お寺様（墓地管理者）への離檀交渉・閉眼供養調整
                </h3>
                <p class="timeline-text">
                  長年お世話になったお寺様へ「墓じまいをしたい」旨を丁寧にお伝えし、檀家を離れる手続き（離檀）を進め、宗教的な魂抜きである「閉眼供養（へいがんくよう）」の法要を行う日程を調整します。
                </p>
                <div class="timeline-detail-box">
                  <strong>ここからのサポート範囲：</strong>「お寺へどう言えばカドが立たないか」の具体的な切り出し方マニュアルを提供し、万が一の揉め事の際にも個別で円満解決に向けた対面アドバイスや手紙（文案）作成などをきめ細やかにサポートします。
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-badge">5</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 5</span>
                  【代行】役所への改葬許可申請・「改葬許可証」の正式交付
                </h3>
                <p class="timeline-text">
                  そろった書類（改葬許可申請書、埋蔵証明書、受入証明書など）を一式まとめて、現在お墓のある${prefecture.name}内の役所の窓口（または郵送）に申請し、正式な公的許可証である「改葬許可証」を交付してもらいます。
                </p>
                <div class="timeline-detail-box">
                  <strong>ここからの代行範囲：</strong>役所への完成書類の提出、不備があった際の修正対応、役所から交付された「改葬許可証」の原本受け取りまで、委任状に基づきすべての行政窓口との対応を代行します。
                </div>
              </div>
            </div>

            <div class="timeline-item">
              <div class="timeline-badge">6</div>
              <div class="timeline-content">
                <h3 class="timeline-title">
                  <span class="timeline-step-tag">Step 6</span>
                  閉眼供養（魂抜き）＆墓石の解体撤去・更地返還
                </h3>
                <p class="timeline-text">
