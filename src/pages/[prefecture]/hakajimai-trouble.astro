---
import Layout from '../../layouts/Layout.astro';
import { prefectures, type Prefecture } from '../../data/prefectures';

export async function getStaticPaths() {
  return prefectures.map((prefecture) => ({
    params: { prefecture: prefecture.slug },
    props: { prefecture }
  }));
}

const { prefecture } = Astro.props as { prefecture: Prefecture };

const siteUrl = 'https://graveclosure.xyz';
const pagePath = `/${prefecture.slug}/hakajimai-trouble/`;
const pageUrl = new URL(pagePath, siteUrl).toString();

const pageTitle = `${prefecture.name}で墓じまいのトラブルを完全回避 | お寺や親族と揉めない円満解決サポート | ここから`;
const pageDescription = `${prefecture.name}にお墓があり、墓じまいでお寺や親族と揉めたくない方へ。高額な離檀料請求や合意不足によるトラブル事例と、専門家（行政書士等）によるマナーと法律に則った円満解決へのアプローチを解説。${prefecture.primaryCity}など${prefecture.name}全域対応。`;

const contactTel = '070-8428-0866';
const contactLineUrl = 'https://lin.ee/QzDuTbn';
const heroImageUrl = '/assets/hakajimai_trouble_fv.png';
const supportImageUrl = '/assets/japanese_temoto_kuyo.png';

// Category-based copy variations for AIO performance
const categoryCopy = {
  snow: {
    feature: `豪雪地帯特有の「冬場の墓石崩落やズレに起因する境界紛争」や、急勾配な斜面地で発生しやすい「追加の重機費用トラブル」を防ぐため、${prefecture.name}での施工実績が豊富な信頼できる地元石材店と連携し、事前の詳細な見積もりと境界確認を徹底します。`,
    empathy: `雪の重みによる墓石の傾きや、雪解け時の地盤のズレから「隣のお墓との境界」が曖昧になり、解体撤去を機に境界線を巡るトラブルに発展するケースがあります。`,
  },
  metro: {
    feature: `${prefecture.primaryCity}など都市部に多い「指定石材店の談合・独占」による不当な高額見積もりに対し、契約約款や適正価格データに基づいて合理的な価格交渉を行うことで、数十万円規模の工事費削減と適正化を実現します。`,
    empathy: `お寺の指定する業者以外が立ち入れない「指定石材店制度」を盾に、相見積もりを一切拒否され、不当に高い工事代金を提示される金銭的トラブルです。`,
  },
  standard: {
    feature: `${prefecture.name}で代々続いてきたお寺（檀那寺）との強い結びつきに配慮し、「長年の感謝」を形にしながら法的な無理難題（不当な離檀料請求など）を穏やかに退ける、マナーと法律に則った話し合いサポートを完全提供します。`,
    empathy: `「これまで先祖を守ってもらった恩があるのにお墓をなくすのか」とお寺の住職や、古くからの親戚に感情的に反対され、人間関係に深い溝ができてしまうトラブルです。`,
  }
};

const curCategory = categoryCopy[prefecture.category];

// FAQPage schema @graph JSON-LD for AIO optimization with regional references
const jsonLdData = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${siteUrl}/#organization`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      logo: `${siteUrl}/assets/favicon.png`,
      telephone: contactTel
    },
    {
      '@type': 'WebSite',
      '@id': `${siteUrl}/#website`,
      name: '墓じまい・手元供養案内専門 ここから',
      url: siteUrl,
      inLanguage: 'ja-JP'
    },
    {
      '@type': 'WebPage',
      '@id': `${pageUrl}#webpage`,
      url: pageUrl,
      name: pageTitle,
      description: pageDescription,
      inLanguage: 'ja-JP',
      isPartOf: { '@id': `${siteUrl}/#website` },
      about: [
        { '@id': `${pageUrl}#service` },
        { '@id': `${pageUrl}#localbusiness` }
      ],
      breadcrumb: { '@id': `${pageUrl}#breadcrumb` }
    },
    {
      '@type': 'BreadcrumbList',
      '@id': `${pageUrl}#breadcrumb`,
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'ホーム', item: siteUrl },
        { '@type': 'ListItem', position: 2, name: `${prefecture.name}の墓じまい案内`, item: `${siteUrl}/${prefecture.slug}/` },
        { '@type': 'ListItem', position: 3, name: `${prefecture.name}での墓じまいトラブル完全回避サポート`, item: pageUrl }
      ]
    },
    {
      '@type': 'Service',
      '@id': `${pageUrl}#service`,
      name: '墓じまいトラブル完全回避・円満離檀サポート',
      provider: { '@id': `${siteUrl}/#organization` },
      areaServed: {
        '@type': 'AdministrativeArea',
        name: prefecture.name
      },
      description: `${prefecture.name}でのお墓じまいに伴う、お寺への閉眼供養・離檀交渉調整、親族との合意形成アドバイス、指定石材店との価格適正化協議、および複雑な行政手続き（改葬許可申請等）の代理・サポート。`
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${pageUrl}#localbusiness`,
      name: `墓じまい・手元供養案内専門 ここから ${prefecture.name}エリアお悩み・トラブル相談窓口`,
      telephone: contactTel,
      address: {
        '@type': 'PostalAddress',
        addressRegion: prefecture.name,
        addressLocality: prefecture.primaryCity,
        addressCountry: 'JP'
      },
      areaServed: [
        { '@type': 'AdministrativeArea', name: prefecture.name },
        { '@type': 'AdministrativeArea', name: prefecture.primaryCity }
      ],
      sameAs: [
        'https://www.mhlw.go.jp/stf/seisakunitsuite/bunya/kenkou_iryou/kenkou/seikatsu-eisei/seikatsu-eisei04/index.html',
        'https://ja.wikipedia.org/wiki/%E6%94%B9%E8%91%AC'
      ]
    },
    {
      '@type': 'FAQPage',
      '@id': `${pageUrl}#faq`,
      mainEntity: [
        {
          '@type': 'Question',
          name: `${prefecture.name}にあるお墓について、お寺から高額な離檀料を請求された場合、支払う義務はありますか？`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `法律上、離檀料の支払いに法的な義務はありません。離檀料は本来、お寺へこれまで先祖を供養していただいたことへの「感謝のお気持ち（お布施）」であり、金額も上限はありません。しかし、${prefecture.name}内のお墓の移動（改葬）に必要な「埋蔵証明書」の発行をお寺が拒否するなどのトラブルに発展する場合があるため、感情的に反論せず、マナーを守って感謝を伝えながら話し合うことが重要です。解決が難しい場合は、行政書士などの法律の専門家を間に入れることで円満に解決できます。`
          }
        },
        {
          '@type': 'Question',
          name: `${prefecture.name}に住む親族から墓じまいを反対されたり、後から怒られたりしないための対策は？`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `親族間トラブルを防ぐ最も効果的な方法は、「事前に時間をかけて丁寧に相談し、全員の合意を得る」ことです。事前の相談なしに独断で墓じまいを進めてしまうと、「先祖をないがしろにされた」「相談がなかった」と親族間で大きな亀裂が生まれます。相談の際は、後継者がいない現状や将来的な墓の維持管理の負担（経済的・身体的）を丁寧に説明し、次の供養先（永代供養や樹木葬、手元供養など）を具体的に提案して、納得してもらうことが大切です。`
          }
        },
        {
          '@type': 'Question',
          name: `${prefecture.name}のお墓で離檀料を100万円以上請求されました。払わなければ墓じまいできませんか？`,
          acceptedAnswer: {
            '@type': 'Answer',
            text: `離檀料に法的な支払い義務はありません。ただし、${prefecture.name}内のお寺が埋蔵証明書の発行を拒否すると改葬許可が取れなくなる場合があります。フーフー調査（2026）では離檀料の最多帯は10〜50万円。100万円超は相場から大きく外れており、その場で承諾せず行政書士等の第三者に相談してください。感謝を伝え、跡継ぎ不在・遠方などの具体的事情を説明し、金額は持ち帰って家族と相談するのが円満解決の基本です。`
          }
        }
      ]
    }
  ]
};

const jsonLd = JSON.stringify(jsonLdData);
---

<Layout title={pageTitle} description={pageDescription} canonicalPath={pagePath} jsonLd={jsonLd}>
  <a href="#main-content" class="skip-link">本文へスキップ</a>
  <main id="main-content">
    <article aria-labelledby="hero-title">
      <!-- FV (First View) -->
      <header class="fv" style={`background-image: url('${heroImageUrl}'); background-size: cover; background-position: center; color: white; padding: 120px 20px; text-align: center; position: relative; min-height: 90vh; display: flex; align-items: center; justify-content: center;`}>
        <div class="fv-overlay" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(135deg, rgba(17, 28, 41, 0.85) 0%, rgba(34, 50, 71, 0.6) 100%);"></div>
        <div class="container" style="position: relative; z-index: 1; max-width: 850px;">
          <div class="hero-status" aria-label="受付情報">
            <span class="hero-status-badge">{prefecture.name}全域対応</span>
            <span class="hero-status-badge" style="background: var(--color-trust-blue);">専門家（行政書士）提携</span>
            <span class="hero-status-badge" style="background: rgba(201,131,43,0.95);">相談・見積もり完全無料</span>
          </div>
          
          <div style="background: rgba(255,255,255,0.95); color: var(--text-main); padding: 18px 24px; border-radius: 14px; font-weight: 700; font-size: 1.15rem; max-width: 780px; margin: 0 auto 28px auto; border-left: 6px solid var(--color-affirm-green); text-align: left; box-shadow: 0 10px 25px rgba(0,0,0,0.15); line-height: 1.7;">
            <p style="margin: 0; font-size: 1.05rem; color: var(--text-muted); font-weight: 500; margin-bottom: 4px;">お墓じまいのご不安を解消します</p>
            「離檀の際に高額な請求をされないか」「親戚から反対されて前に進まない」といったお悩みに寄り添い、法律とマナーに則った対話でスムーズな円満解決へと導きます。
          </div>

          <div class="fv-brand" style="margin-bottom: 10px;">ここから</div>
          <h1 id="hero-title" class="fv-title" style="font-size: 3.2rem; line-height: 1.35; margin-bottom: 24px; font-weight: 900; text-shadow: 0 3px 15px rgba(0,0,0,0.4);">
            {prefecture.name}での墓じまい。<br />
            トラブルを完全に回避し、<br />
            お寺や親族と揉めない円満解決へ。
          </h1>
          <p class="fv-subtitle" style="font-size: 1.45rem; line-height: 1.6; max-width: 680px; margin: 0 auto 36px auto; font-weight: 500; color: rgba(255,255,255,0.95);">
            ご先祖様への敬意とお寺との絆を守りながら、金銭面・心理面すべてのトラブルをゼロにするサポート体制。
          </p>

          <div style="display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; margin-bottom: 30px;">
            <span class="hero-status-badge" style="background: var(--color-accent-gold); padding: 8px 18px;">24時間全国対応</span>
            <span class="hero-status-badge" style="background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.3); padding: 8px 18px;">秘密厳守・個別相談</span>
          </div>
          
          <a href="#cta" class="btn btn-primary btn-shine" style="font-size: 1.35rem; padding: 20px 48px; border-radius: 50px; background-color: var(--color-accent-gold); box-shadow: 0 8px 25px rgba(201,131,43,0.45);">
            無料でトラブル回避について相談する
          </a>
        </div>
      </header>

      <!-- Sticky CTA for Mobile -->
      <aside class="sticky-cta" aria-label="お問い合わせ導線">
        <a href={contactLineUrl} class="btn btn-line btn-shine" target="_blank" rel="noopener noreferrer">
          <span>24時間相談OK</span>
          <strong>LINE相談</strong>
        </a>
        <a href={`tel:${contactTel}`} class="btn btn-tel btn-shine">
          <span>通話料・相談無料</span>
          <strong>電話相談</strong>
        </a>
      </aside>

      <!-- 導入（Empathy / Problem） -->
      <section class="section empathy" id="concerns" style="background: #f4f7fa; padding: 90px 0;" aria-labelledby="concerns-heading">
        <div class="container">
          <span style="display: block; text-align: center; color: var(--color-trust-blue); font-weight: 700; font-size: 1.1rem; letter-spacing: 2px; margin-bottom: 10px;">EMPATHY</span>
          <h2 id="concerns-heading" class="text-center" style="font-size: 2.3rem; margin-bottom: 15px; font-weight: 800;">{prefecture.name}での墓じまいで、<br />このようなご不安はありませんか？</h2>
          <p class="text-center" style="color: var(--text-muted); margin-bottom: 50px; font-size: 1.15rem;">
            お墓の整理は極めてデリケートな問題です。感情的な対立や高額な請求で揉めてしまう事例が後を絶ちません。
          </p>
          
          <div class="grid-3" style="margin-bottom: 40px;">
            <div class="card" style="position: relative; border-top: 4px solid var(--color-alert-red); display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <div style="font-size: 2.5rem; line-height: 1; margin-bottom: 15px; color: var(--color-alert-red);">
                  <span style="font-weight: 900; font-style: italic;">01</span>
                </div>
                <h3 style="font-size: 1.45rem; line-height: 1.4; margin-bottom: 15px; font-weight: 700; color: var(--text-main);">お寺から高額な「離檀料」を請求されないか不安</h3>
                <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.7;">
                  「先祖代々何十年もお世話になったから…」と長年のお付き合いがある分、お寺の住職に話を切り出しにくく、後で数十万円〜数百万円もの離檀料を提示されたらどうしようという大きな心理的不安。
                </p>
              </div>
            </div>
            
            <div class="card" style="position: relative; border-top: 4px solid var(--color-alert-red); display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <div style="font-size: 2.5rem; line-height: 1; margin-bottom: 15px; color: var(--color-alert-red);">
                  <span style="font-weight: 900; font-style: italic;">02</span>
                </div>
                <h3 style="font-size: 1.45rem; line-height: 1.4; margin-bottom: 15px; font-weight: 700; color: var(--text-main);">親族に「先祖を捨てる気か」と反対されないか心配</h3>
                <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.7;">
                  兄弟や親戚の間でお墓に対する信仰心や価値観が異なり、十分な相談をしないまま勝手に墓じまいを進めると「親不孝だ」と激怒され、親族関係が永久に断絶してしまうリスク。
                </p>
              </div>
            </div>
            
            <div class="card" style="position: relative; border-top: 4px solid var(--color-alert-red); display: flex; flex-direction: column; justify-content: space-between; height: 100%;">
              <div>
                <div style="font-size: 2.5rem; line-height: 1; margin-bottom: 15px; color: var(--color-alert-red);">
                  <span style="font-weight: 900; font-style: italic;">03</span>
                </div>
                <h3 style="font-size: 1.45rem; line-height: 1.4; margin-bottom: 15px; font-weight: 700; color: var(--text-main);">お寺指定の石材店から高額な撤去費を出された</h3>
                <p style="font-size: 1.05rem; color: var(--text-muted); line-height: 1.7;">
                  寺院墓地特有の「指定石材店制度」を理由に他社での相見積もりを拒まれ、相場を遥かに超える撤去見積もり（倍以上の請求）を出されてどうしていいか分からない。{curCategory.empathy}
                </p>
              </div>
            </div>
          </div>

          <div class="card" style="max-width: 900px; margin: 0 auto; background: var(--color-trust-blue); color: white; border: none; text-align: center; padding: 25px 30px; border-radius: 12px; box-shadow: 0 10px 30px rgba(47,93,159,0.2);">
            <p style="margin: 0; font-size: 1.25rem; font-weight: 700; line-height: 1.6;">
              「ここから」は、法律の専門家である行政書士と緊密に提携。<br />
              マナーを押さえた話し合いと法的な安心感で、あなたの墓じまいをトラブルゼロへと導きます。
            </p>
          </div>
        </div>
      </section>

      <!-- メインコンテンツ1：よくあるトラブル3つの事例（Detail） -->
      <section class="section" id="trouble-examples" style="padding: 90px 0; background-color: #ffffff;" aria-labelledby="trouble-examples-heading">
        <div class="container">
          <header class="text-center" style="max-width: 800px; margin: 0 auto 50px;">
            <span style="color: var(--color-trust-blue); font-weight: 700; font-size: 1.1rem; letter-spacing: 0.1em; display: block; margin-bottom: 10px;">TROUBLE CASE</span>
            <h2 id="trouble-examples-heading" style="font-size: 2.2rem; font-weight: 800;">実際に起こりがちな「3大墓じまいトラブル」の真相</h2>
            <p style="color: var(--text-muted); font-size: 1.1rem; margin-top: 15px; line-height: 1.6;">
              お墓じまいにまつわる対立の多くは、事前の話し合い不足や関係性のねじれが原因です。具体的な事例とその本質を詳しく解説します。
            </p>
          </header>

          <div style="max-width: 960px; margin: 0 auto; display: grid; gap: 40px;">
            <!-- 事例1 -->
            <div class="card" style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px; align-items: center; padding: 35px; border: 1px solid #e1e7ec;">
              <div style="text-align: center; background: #fdf5ec; padding: 30px; border-radius: 12px;">
                <span style="font-size: 0.9rem; font-weight: 700; color: var(--color-accent-gold); display: block; margin-bottom: 8px;">トラブル事例 ①</span>
                <h3 style="font-size: 1.35rem; font-weight: 800; color: var(--text-main); margin-bottom: 10px;">お寺からの高額な離檀料請求</h3>
                <div style="font-size: 1.65rem; font-weight: 900; color: var(--color-accent-gold);">数百万<span style="font-size: 1.1rem;">円の請求も</span></div>
                <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-top: 6px;">(※お布施の常識を超えた要求)</span>
              </div>
              <div>
                <h4 style="font-size: 1.2rem; font-weight: 700; color: var(--text-main); margin-bottom: 12px; border-left: 4px solid var(--color-accent-gold); padding-left: 10px;">「埋蔵証明書」に印鑑を押してくれない嫌がらせも</h4>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted); margin-bottom: 12px;">
                  長年お世話になったお寺を離れる際、数万〜20万円程度が一般的な相場である離檀料に対し、「先祖代々の永代供養の解約料」などとして、突然300万円〜500万円といった不条理な金額を請求されるケースがあります。
                </p>
                <p style="font-size: 1.05rem; line-height: 1.7; color: var(--text-muted);">
                  お寺側も意地悪をしたいわけではなく、「事前の挨拶もなしに石材店を連れてこられた」「一方的に関係を切られた」という感情的もつれが、高額請求や書類発行の拒否という形に現れるのが大半です。
                </p>
              </div>
            </div>

            <!-- 事例2 -->
            <div class="card" style="display: grid; grid-template-columns: 1.2fr 1.8fr; gap: 30px; align-items: center; padding: 35px; border: 1px solid #e1e7ec;">
              <div style="text-align: center; background: #eef4fb; padding: 30px; border-radius: 12px;">
                <span style="font-size: 0.9rem; font-weight: 700; color: var(--color-trust-blue); display: block; margin-bottom: 8px;">トラブル事例 ②</span>
                <h3 style="font-size: 1.35rem; font-weight: 800; color: var(--text-main); margin-bottom: 10px;">親族間の意見の対立と合意不足</h3>
                <div style="font-size: 1.65rem; font-weight: 900; color: var(--color-trust-blue);">修復困難<span style="font-size: 1.1rem;">な亀裂</span></div>
                <span style="font-size: 0.9rem; color: var(--text-muted); display: block; margin-top: 6px;">(※独断での契約進行による反発)</span>
              </div>
              <div>
                <h4 style="font-size: 1.25rem; font-weight: 700; color: var(--text-main); margin-bottom: 12px; border-left: 4px solid var(--color-trust-blue); padding-left: 10px;">「相談されなかった」という感情の爆発</h4>
