---
export interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: string;
  isPortal?: boolean;
}

const { title, description, canonicalPath, jsonLd, isPortal = false } = Astro.props;
const siteUrl = "https://graveclosure.xyz";
const canonicalUrl = canonicalPath ? new URL(canonicalPath, siteUrl).toString() : siteUrl;
const ogImageUrl = new URL('/assets/fv_bg.png', siteUrl).toString();
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta name="google-site-verification" content="_b12ZyymqArb2dY_eOrWKCMf97RCWINOTxxow51hE34" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    {description && <meta name="twitter:description" content={description} />}
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    
    <!-- 全体共通CSS -->
    {isPortal ? (
        <style>
            .portal-container {
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                min-height: 100vh;
                background: #f9f9f9;
                padding: 20px;
            }
            .portal-title {
                font-size: 2.5rem;
                color: #2C3E50; /* var(--color-trust-blue) placeholder */
                margin-bottom: 30px;
                text-align: center;
            }
            .region-links {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
                gap: 14px;
                justify-content: center;
            }
            .region-card {
                background: white;
                padding: 22px 14px;
                border-radius: 10px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.1);
                text-decoration: none;
                color: #333; /* var(--text-main) placeholder */
                font-size: 1.5rem;
                font-weight: bold;
                transition: transform 0.3s ease;
                text-align: center;
                min-width: 180px;
            }
            .region-card:hover {
                transform: translateY(-5px);
            }
            .skip-link {
                position: absolute;
                left: -9999px;
                top: 0;
                z-index: 2000;
                background: #fff;
                color: #111;
                padding: 10px 14px;
                border: 2px solid #111;
            }
            .skip-link:focus {
                left: 12px;
                top: 12px;
            }
        </style>
    ) : (
        <link rel="stylesheet" href="/css/style.css">
    )}
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&display=swap" rel="stylesheet">
    
    {jsonLd && <script type="application/ld+json" set:html={jsonLd}></script>}
</head>
<body>
    <slot />

    {!isPortal && (
        <footer class="section" style="background: #223247; color: #ffffff; padding-bottom: 24px; border-top: 4px solid #2f8f6b;">
            <div class="container text-center" data-aos>
                <h2 style="font-size: 2.1rem; line-height: 1.4;">「私たちが選ぶ、いちばん優しい終わらせ方。」</h2>
                <p style="margin-bottom: 24px; font-size: 1.25rem; font-weight: 700;">墓じまい案内専門「ここから」</p>
                <p style="font-size: 1.4rem; font-weight: 700;">お問い合わせ：070-8428-0866</p>
                <p style="font-size: 1.2rem; font-weight: 700; color: #cfe9dd;">24時間受付中 / 年中受付中</p>
            </div>
            <div class="container text-center" style="font-size: 1rem; border-top: 1px solid rgba(255,255,255,0.25); padding-top: 20px;">
                <a href="/tokushoho/" style="color: #ffffff; margin: 0 10px; font-weight: 700; text-decoration: underline;">特定商取引法に基づく表記</a>
                <a href="/privacy/" style="color: #ffffff; margin: 0 10px; font-weight: 700; text-decoration: underline;">プライバシーポリシー</a>
                <p style="margin-top: 12px; font-size: 1rem;">&copy; 2024 ここから. All Rights Reserved.</p>
            </div>
        </footer>
    )}
</body>
</html>
